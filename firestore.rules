rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // Checks if the requesting user is a player in the given game.
    // Uses a get() so reads one extra document — acceptable for a game with ≤8 players.
    function isPlayerInGame(gameId) {
      return isAuthenticated() &&
        request.auth.uid in
          get(/databases/$(database)/documents/games/$(gameId)).data.turnOrder;
    }

    match /games/{gameId} {
      // Readable by any player who has joined (i.e. is in turnOrder).
      // The lobby doc is readable as soon as the host creates the game and
      // joins are done via Cloud Functions, so non-members never need direct access.
      allow read: if isAuthenticated() &&
                     request.auth.uid in resource.data.turnOrder;

      // All writes go through Cloud Functions (admin SDK bypasses rules).
      allow write: if false;

      // Public player info — name, score, hand size, isDown.
      // Readable by everyone in the game.
      match /players/{uid} {
        allow read: if isPlayerInGame(gameId);
        allow write: if false;
      }

      // Private hand — only the owning player can read their own cards.
      match /hands/{uid} {
        allow read: if isAuthenticated() && request.auth.uid == uid;
        allow write: if false;
      }

      // Game event log — readable by all players in the game.
      match /log/{entry} {
        allow read: if isPlayerInGame(gameId);
        allow write: if false;
      }

      // Server-only data (deck). The admin SDK bypasses these rules,
      // so Cloud Functions can still read/write. No client ever can.
      match /private/{document=**} {
        allow read, write: if false;
      }
    }
  }
}
